<UserControl x:Class="WPFUI.Controls.MovementControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFUI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Lavender">
        <Button HorizontalAlignment="Center" VerticalAlignment="Top" Content="North" Width="100" Height="40" Click="MoveNorth"/>
        <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Content="South" Width="100" Height="40" Click="MoveSouth"/>
        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="East" Width="100" Height="40" Click="MoveEast"/>
        <Button HorizontalAlignment="Left" VerticalAlignment="Center" Content="West" Width="100" Height="40" Click="MoveWest"/>
    </Grid>
</UserControl>
